{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "maxLength": 250,
      "required": true
    },
    "category": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "News",
        "Events",
        "Promotions",
        "Announcement",
        "Shopping Tips"
      ]
    },
    "content": {
      "type": "blocks",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "maxLength": 500
    },
    "featured_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "published_time": {
      "type": "date"
    },
    "author": {
      "type": "string",
      "default": "Supermal Karawaci",
      "required": true
    },
    "is_featured": {
      "type": "boolean",
      "default": false
    }
  }
}
